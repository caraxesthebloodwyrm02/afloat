{
  "name": "afloat",
  "version": "0.1.1",
  "private": true,
  "description": "A no-fluff cognitive assistant for quick decision support (~2 min sessions)",
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "scripts": {
    "dev": "node start-dev.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:risk": "npx tsx scripts/test-risk-assessment.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "pre-commit": "npm run lint && npm run typecheck && npm run test",
    "clean": "rm -rf .next out coverage"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.37.0",
    "groq-sdk": "1.1.2",
    "jose": "6.2.2",
    "next": "16.2.1",
    "openai": "6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "21.0.1",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "11.0.0",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prettier": "^3.0.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "4.1.2"
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false
  }
}

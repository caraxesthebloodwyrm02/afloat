{
  "name": "afloat",
  "version": "0.1.1",
  "private": true,
  "description": "A no-fluff cognitive assistant with Ollama-first routing for quick decision support",
  "engines": {
    "node": ">=22.0.0 <26"
  },
  "scripts": {
    "dev": "node start-dev.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --ignore-pattern coverage",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --ignore-pattern coverage --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:routing": "vitest run tests/llm.test.ts tests/session-message-request.test.ts tests/session-message-adapter.test.ts tests/smoke.test.ts tests/api-routes.test.ts tests/consent.test.ts",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:risk": "npx tsx scripts/test-risk-assessment.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:smoke && npm run build",
    "pre-commit": "npm run lint && npm run typecheck && npm run test",
    "clean": "rm -rf .next out coverage"
  },
  "dependencies": {
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.37.0",
    "actionlint": "^2.0.6",
    "jose": "6.2.2",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "stripe": "22.1.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "11.0.0",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "4.1.5"
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false
  }
}

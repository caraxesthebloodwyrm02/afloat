# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                # Optional: OpenRouter or compatible endpoint override
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...

# Session Store + Rate Limiting (Step 2)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Auth (Step 6)
JWT_SECRET=change-this-to-a-random-secret

# Access Control — comma-separated user_id allowlist (optional; unset = allow all authenticated)
# ALLOWED_CALLERS=user-1,user-2

# Stripe (Step 6)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_CONTINUOUS_PRICE_ID=price_...
STRIPE_METER_EVENT_NAME=afloat_session_minutes

# Provenance Chain (separate from JWT — mandatory)
PROVENANCE_SIGNING_KEY=change-this-to-a-different-random-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 4 controlled integration (default off)
PHASE4_MESSAGE_CAPABILITY_ENABLED=false

# Cron Job Authorization (Step 7)
CRON_SECRET=change-this-to-a-random-secret-for-cron-jobs
